def _register_dynamic_adapter(data: Dict[str, Any]) -> None:
    """Registriert Adapter, die *nicht* in der YAML‑Config stehen.

    Idee:
    - Ein externer Adapter‑Prozess (z.B. in ``device_adapters/``) sendet Messwerte
      an ``POST /api/ingest``.
    - Anhand der Felder ``device_id`` oder ``device`` wird ein logischer
      Geräte‑Identifier abgeleitet.
    - Falls dieses Gerät nicht bereits in ``config.yaml`` unter ``adapters``
      existiert, wird es in einer In‑Memory‑Liste ``dynamic_adapters``
      registriert.

    Dadurch tauchen auch Adapter, die nicht vorab in der Konfiguration
    eingetragen wurden, automatisch im Geräte‑Bereich des Frontends auf.
    """
    # Globale App‑Config betrachten
    config = app_state.get("config", {})
    configured = (config.get("adapters") or {}).keys()

    # Mögliche Feldnamen aus dem Adapter‑Payload
    device_id = (
        data.get("device_id")
        or data.get("device")
        or data.get("id")
    )

    if not device_id:
        # Ohne Identifier können wir kein Gerät registrieren
        return

    # Bereits in YAML‑Config oder schon dynamisch bekannt -> nichts tun
    if device_id in configured or device_id in dynamic_adapters:
        # Optional: Last‑Seen aktualisieren
        entry = dynamic_adapters.get(device_id)
        if entry is not None:
            entry["last_seen"] = data.get("timestamp")
        return

    device_type = (
        (data.get("device_type") or data.get("type") or "generic").lower()
    )
    name = data.get("name") or f"{device_type.capitalize()} {device_id}"

    entry = {
        "id": device_id,
        "type": device_type,
        "name": name,
        "source": "dynamic",
        "status": "online",
        "last_seen": data.get("timestamp"),
    }
    dynamic_adapters[device_id] = entry

    # Falls der Adapter im Kontext eines konkreten Verbindungsversuchs
    # gestartet wurde, kann eine optionale request_id mitgeschickt werden.
    # Damit lässt sich der Verbindungsstatus fachlich verfolgen.
    req_id = data.get("request_id")
    if req_id and req_id in pending_connections:
        pending_connections[req_id]["status"] = "connected"
        pending_connections[req_id]["device_id"] = device_id
        pending_connections[req_id]["last_seen"] = data.get("timestamp")
        # Notify any websocket clients about the connection status change
        try:
            # schedule async broadcast so this sync function doesn't block
            asyncio.create_task(broadcast_connection_event({
                "type": "connection_update",
                "request_id": req_id,
                "status": "connected",
                "device_id": device_id,
                "last_seen": data.get("timestamp"),
            }))
        except Exception:
            # best-effort
            pass


# REST endpoint for device adapters to ingest measurement data
@app.post("/api/ingest")
async def ingest_measurement(request: Request):
    """Ingest‑Endpoint für externe Adapter‑Prozesse.

    Erwarteter Body (Minimalbeispiel):

    {
      "device_id": "smartmeter_1",   # oder "device": "smartmeter_1"
      "device_type": "smartmeter",   # optional, sonst "generic"
      "power": 1234,
      "voltage": 230.1,
      "current": 5.2,
      "timestamp": "2026-04-04T12:34:56Z"
    }

    Wichtig: Wenn ``device_id``/``device`` nicht in ``config.yaml`` vorkommt,
    wird der Adapter automatisch als dynamisches Gerät registriert und
    erscheint anschließend im Geräte‑Bereich des Frontends.
    """
    try:
        data = await request.json()

        # Dynamische Adapter‑Registrierung (auch wenn Influx aus ist)
        if isinstance(data, dict):
            _register_dynamic_adapter(data)

        if not influx_writer:
            return {"error": "InfluxDB nicht verfügbar"}

        await influx_writer.write(data)
        return {"status": "ok"}
    except Exception as e:
        return {"error": str(e)}


async def broadcast_connection_event(event: Dict[str, Any]) -> None:
    """Broadcast a small JSON event to all connected websocket clients.

    Event format is intentionally generic; frontend can filter by `type`.
    """
    # clients is a runtime list of WebSocket objects; iterate over a copy
    try:
        for ws in list(clients):
            try:
                await ws.send_json(event)
            except Exception:
                # remove dead sockets
                try:
                    await ws.close()
                except Exception:
                    pass
                if ws in clients:
                    clients.remove(ws)
    except NameError:
        # clients may not be defined yet at import time; ignore if so
        return
