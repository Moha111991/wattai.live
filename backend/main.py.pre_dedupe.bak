influx_writer = None
clients: List[WebSocket] = []
mobile_clients = []
app_state = {"config": load_config()}


# Import routers for energy, reporting, alarms
from backend.routes.energy_management import router as energy_router
from backend.routes.reporting import router as reporting_router
from backend.routes.alarms import router as alarms_router

# EV Runtime Vars (für /ws/mobile updates)
ev_soc = 0.0
ev_power_kw = 0.0
ev_charging = False




@fleet_router.get("/fleet/ai_recommendation", dependencies=[Depends(get_api_key)])
async def fleet_ai_recommendation():
    """
    Gibt für alle aktiven EVs/Wallboxen die aktuelle KI-Empfehlung und zugewiesene Ladeleistung zurück.
    Berücksichtigt PV-Überschuss, Peak Shaving und gleichmäßige Verteilung.
    """
    # Hole Konfiguration und aktive EVs/Wallboxen
    config = app_state["config"]
    ev_profiles = config.get("ev_profiles", {})
    adapters = config.get("adapters", {})
    # Finde alle aktiven Wallboxen/EVs
    active_wallboxes = [
        (k, v) for k, v in adapters.items()
        if v.get("type", "").lower() == "wallbox" and v.get("enabled", True)
    ]
    # Annahme: Jedes Fahrzeug ist an eine Wallbox gekoppelt
    # Hole aktuelle Systemdaten
    from backend.services.pv_service import pv_service
    snap = pv_service.snapshot()
    pv_power = snap.get("pv_power_kw", 0)
    house_load = snap.get("house_load_w", 0) / 1000
    grid_price = 0.28
    hour = datetime.now().hour
    # Gesamtleistungs-Limit (Peak Shaving)
    max_total_power = 22.0 if len(active_wallboxes) > 1 else 11.0
    # Verfügbare Ladeleistung: PV-Überschuss + ggf. Netz (hier: PV-Überschuss bevorzugt)
    pv_surplus = max(0.0, pv_power - house_load)
    available_power = min(max_total_power, pv_surplus if pv_surplus > 0 else max_total_power)
    # Gleichmäßig verteilen (kann später nach Priorität gewichtet werden)
    per_ev_power = available_power / max(1, len(active_wallboxes))
    # KI-Empfehlung pro EV/Wallbox
    from backend.ai_controller import get_ai_controller
    controller = await get_ai_controller()
    results = []
    for wallbox_id, wallbox in active_wallboxes:
        ev_id = wallbox.get("ev_id") or wallbox_id
        ev_profile = ev_profiles.get(ev_id, {})
        ev_soc = snap.get("ev_soc", 50)
        # Individuelle Ladefenster (optional, hier als Beispiel: nachts 22-6 Uhr)
        charge_window = wallbox.get("charge_window") or {"start": 22, "end": 6}
        # Individuelle max. Ladeleistung
        max_ev_power = min(wallbox.get("power_kw", 11.0), ev_profile.get("max_charge_kw", 11.0))
        # Systemdaten für dieses EV
        current_data = {
            "pv_power": pv_power,
            "battery_soc": snap.get("battery_soc", 50),
            "ev_soc": ev_soc,
            "household_load": house_load,
            "grid_price": grid_price,
            "hour": hour,
            "temperature": snap.get("temperature", 20),
            "ev_connected": True
        }
        # KI-Empfehlung abrufen (mit Flottenparametern)
        ai_result = await controller.get_optimal_action(
            current_data,
            charge_window=charge_window,
            max_total_power_kw=per_ev_power,
            pv_surplus_only=True
        )
        # Begrenze auf max_ev_power
        ai_result["ev_charge_rate"] = min(ai_result["ev_charge_rate"], max_ev_power)
        results.append({
            "wallbox_id": wallbox_id,
            "ev_id": ev_id,
            "empfohlene_leistung_kw": round(ai_result["ev_charge_rate"], 2),
            "grund": ai_result.get("explanation", ""),
            "soc": ev_soc
        })
    return {"fleet_recommendations": results, "gesamtleistung_kw": round(available_power, 2), "pv_surplus_kw": round(pv_surplus, 2)}

app.include_router(fleet_router)

