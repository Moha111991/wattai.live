@app.post("/v2h/disable")
async def v2h_disable():
    """Deaktiviert Vehicle-to-Home (V2H).

    Setzt ev_v2h=False und reduziert die V2H-Leistung auf 0 kW im Status.
    """
    await state.update({"ev_v2h": False, "ev_power_w": 0.0})
    current = await state.get()
    house_power_kw = None
    if current.get("house_load_w") is not None:
        house_power_kw = float(current.get("house_load_w") or 0.0) / 1000.0

    return {
        "success": True,
        "active": False,
        "power_kw": 0.0,
        "house_power_kw": house_power_kw,
        "error": None,
    }



@app.post("/v2h/enable")
async def v2h_enable(payload: Dict[str, Any] = Body(None)):
    """Aktiviert Vehicle-to-Home (V2H).

    Optional kann eine bevorzugte Wallbox-ID übergeben werden, die im Status
    (`preferred_wallbox_id`) reflektiert wird. Die eigentliche Leistungssteuerung
    erfolgt später über den V2H-Controller; hier wird zunächst nur der Status
    im RealtimeState gesetzt, damit das Frontend sauber arbeiten kann.
    """
    # V2H-Flag im zentralen Zustand aktivieren; Leistungszuweisung erfolgt separat.
    await state.update({"ev_v2h": True})
    current = await state.get()

    house_power_kw: Optional[float] = None
    if current.get("house_load_w") is not None:
        house_power_kw = float(current.get("house_load_w") or 0.0) / 1000.0

    # Preferred Wallbox aus Payload (falls vorhanden) im Config-State hinterlegen,
    # damit /v2h/status diese ID zurückgeben kann.
    preferred_id = None
    if payload and isinstance(payload, dict):
        preferred_id = payload.get("wallbox_id")
        if preferred_id:
            cfg = app_state.get("config", {})
            cfg["preferred_wallbox_id"] = preferred_id
            app_state["config"] = cfg

    return {
        "success": True,
        "active": True,
        "power_kw": float(current.get("ev_power_w") or 0.0) / 1000.0,
        "house_power_kw": house_power_kw,
        "error": None,
        "preferred_wallbox_id": preferred_id,
    }

