# Adapter, die nicht explizit in config.yaml definiert sind, aber
# Messdaten an /api/ingest senden, werden hier zur Laufzeit gesammelt.
# Diese Liste wird mit den statischen Adaptern zusammengeführt, wenn
# das Frontend /devices abfragt.
dynamic_adapters: Dict[str, Dict[str, Any]] = {}

# Zuordnung für Verbindungsversuche aus dem UI ("Gerät verbinden")
# auf Basis einer fachlichen Request-ID. Damit kann das Frontend
# optional einen konkreten Connect-Versuch verfolgen.
pending_connections: Dict[str, Dict[str, Any]] = {}


# --- Devices and EV Profiles Endpoints ---
from fastapi import Response

@app.get("/devices")
async def get_devices():
    """Liefert Geräte aus config.yaml *und* dynamisch entdeckte Adapter.

    - Statische Adapter: ``config.yaml -> adapters``
    - Dynamische Adapter: werden über ``POST /api/ingest`` registriert,
      wenn ein unbekannter ``device_id``/``device`` gemeldet wird.
    """
    config = app_state["config"]
    adapters = config.get("adapters", {}) or {}

    # Statische Geräte aus config.yaml
    devices = [dict(id=k, **v) for k, v in adapters.items()]

    # Dynamisch registrierte Adapter ergänzen (ohne Duplikate)
    for dev_id, meta in dynamic_adapters.items():
        if not any(d.get("id") == dev_id for d in devices):
            devices.append(meta)

    return {"devices": devices}


@app.get("/devices/{device_id}/details")
async def get_device_details(device_id: str):
  """Liefert Detailstatus für ein Gerät.

  Aktuell ist nur ein sinnvoller Laufzeitstatus für Wallboxen (z.B. go-eCharger)
  implementiert. Für andere Gerätetypen wird eine einfache Stub-Antwort
  mit Basisinformationen zurückgegeben.
  """
  config = app_state.get("config", {})
  adapters = config.get("adapters", {}) or {}
  dev = adapters.get(device_id)
  if not dev:
      raise HTTPException(status_code=404, detail="Device not found")

  dev_type = (dev.get("type") or "").lower()

  # Nur für Wallboxen versuchen wir, einen echten Status per HTTP abzufragen.
  if dev_type != "wallbox":
      return {
          "device_id": device_id,
          "type": dev.get("type"),
          "online": False,
          "status": "unsupported",
          "ev_connected": False,
          "connector_locked": False,
          "power_kw": 0.0,
          "soc": None,
          "v2h_ready": bool(dev.get("v2h_capable", False)),
          "error": "Status-Endpunkt ist derzeit nur für Wallboxen implementiert.",
      }

  host = dev.get("ip") or dev.get("host")
  if not host:
      return {
          "device_id": device_id,
          "type": dev.get("type"),
          "online": False,
          "status": "config_error",
          "ev_connected": False,
          "connector_locked": False,
          "power_kw": 0.0,
          "soc": None,
          "v2h_ready": bool(dev.get("v2h_capable", False)),
          "error": "Keine IP/Host für Wallbox in der Konfiguration hinterlegt.",
      }

  try:
      async with httpx.AsyncClient(timeout=5) as client:
          r = await client.get(f"http://{host}/api/status")
          r.raise_for_status()
          data = r.json()
  except Exception as e:
      return {
          "device_id": device_id,
          "type": dev.get("type"),
          "online": False,
          "status": "offline",
          "ev_connected": False,
          "connector_locked": False,
          "power_kw": 0.0,
          "soc": None,
          "v2h_ready": bool(dev.get("v2h_capable", False)),
          "error": f"Fehler bei Statusabfrage der Wallbox: {e}",
      }

  # go-e spezifische Auswertung
  car_state = data.get("car", 0)
  # einfache Heuristik: car_state > 0 bedeutet Fahrzeug erkannt/angeschlossen
  ev_connected = car_state in (1, 2, 3, 4)
  charging_state_map = {1: "ready", 2: "charging", 3: "waiting", 4: "done"}
  charging_state = charging_state_map.get(car_state, "unknown")

  nrg = data.get("nrg", [0] * 16)
  power_w = nrg[11] if len(nrg) > 11 else 0
  power_kw = round(float(power_w) / 1000.0, 3)

  soc = data.get("soc")

  # V2H-Bereitschaft: hängt von Konfiguration und angeschlossenem Fahrzeug ab.
  v2h_ready = bool(dev.get("v2h_capable", False) and ev_connected)

  return {
      "device_id": device_id,
      "type": dev.get("type"),
      "online": True,
      "status": charging_state,
      "ev_connected": ev_connected,
      # Konnektorverriegelung: hier vereinfachend gleichgesetzt mit "Fahrzeug erkannt".
      "connector_locked": ev_connected,
      "power_kw": power_kw,
      "soc": soc,
      "v2h_ready": v2h_ready,
      "error": None,
  }


@app.post("/devices/{device_id}/connect")
async def connect_device(device_id: str, payload: Dict[str, Any] = Body(None)):
    """Startet einen Verbindungsversuch für ein Gerät.

    Das Frontend kann optional eine ``request_id`` mitsenden. Falls keine
    angegeben wird, generiert das Backend eine neue UUID.

    Die so erzeugte Request-ID kann genutzt werden, um den Status eines
    bestimmten "Gerät verbinden"-Klicks fachlich nachzuverfolgen.
    """
    from datetime import datetime

    body: Dict[str, Any] = payload or {}
    request_id = body.get("request_id") or str(uuid4())

    pending_connections[request_id] = {
        "device_id": device_id,
        "status": "pending",
        "created_at": datetime.utcnow().isoformat(),
        "params": body,
    }

    # Broadcast pending state to websocket clients (best-effort)
    try:
        asyncio.create_task(broadcast_connection_event({
            "type": "connection_update",
            "request_id": request_id,
            "status": "pending",
            "device_id": device_id,
            "created_at": pending_connections[request_id]["created_at"],
        }))
    except Exception:
        pass

    return {"request_id": request_id, "status": "pending"}


@app.get("/connections/{request_id}")
async def get_connection_status(request_id: str):
    """Gibt den Status eines Verbindungsversuchs anhand der Request-ID zurück."""
    info = pending_connections.get(request_id)
    if not info:
        raise HTTPException(status_code=404, detail="Connection not found")
    return info


@app.get("/smartmeter/energy")
async def smartmeter_energy():
    """Aggregierte Energiewerte des Smart Meters.

    Die Daten stammen aus dem zentralen `RealtimeState`, der u.a. über `mqtt_service`
    aus den Topics `energy/smartmeter/import_kwh` und `energy/smartmeter/export_kwh`
    gespeist wird. Das Frontend erwartet folgende Struktur:

    {
      "import_kwh": number | null,
      "export_kwh": number | null,
      "power_w": number | null,
      "voltage_v": number | null,
      "current_a": number | null,
      "energy_today_kwh": number | null,
      "energy_total_kwh": number | null
    }

    Nicht vorhandene Werte werden als null zurückgegeben, damit das Frontend
    sie robust mit "-" darstellen kann.
    """
    current = await state.get()

    import_kwh = current.get("smartmeter_import_kwh")
    export_kwh = current.get("smartmeter_export_kwh")

    # Versuche eine sinnvolle Leistungsableitung: bevorzugt Netzübergang,
    # ansonsten Hauslast, falls vorhanden.
    power_w: Optional[float] = None
    grid_import_w = current.get("grid_import_w")
    grid_export_w = current.get("grid_export_w")
    house_load_w = current.get("house_load_w")

    if grid_import_w is not None or grid_export_w is not None:
        power_w = float(grid_import_w or 0.0) - float(grid_export_w or 0.0)
    elif house_load_w is not None:
        power_w = float(house_load_w or 0.0)

    return {
        "import_kwh": import_kwh,
        "export_kwh": export_kwh,
        "power_w": power_w,
        # Diese Felder sind optional und können später durch Erweiterung
        # des MQTT-Adapters/States mit echten Werten befüllt werden.
        "voltage_v": None,
        "current_a": None,
        "energy_today_kwh": None,
        "energy_total_kwh": None,
    }


@app.get("/ev/cloud_status")
async def ev_cloud_status():
    """Stub-Endpoint für optionale SOC-Daten aus der Fahrzeug-Cloud/BMS.

    Frontend erwartet eine Struktur wie {"available": bool, "soc": number, "provider": str|null}.
    Aktuell ist keine echte Cloud-Integration implementiert, daher liefern wir einen
    sauberen Fallback, der lediglich signalisiert, dass keine Cloud-Daten vorliegen.
    """
    return {"available": False, "soc": None, "provider": None}


@app.get("/v2h/status")
async def v2h_status(wallbox_id: Optional[str] = Query(None)):
    """Gibt den aktuellen V2H-Status zurück.

    Diese Struktur ist auf das Frontend `ElektroautoV2H` abgestimmt und enthält
    neben Aktiv-Status und Leistung auch Metadaten zur (optionalen) Wallbox.
    """
    current = await state.get()

    # Basisleistungswerte aus dem Realtime-State ableiten
    active = bool(current.get("ev_v2h") is True)
    ev_power_w = float(current.get("ev_power_w") or 0.0)
    power_kw = ev_power_w / 1000.0

    house_power_kw: Optional[float] = None
    if current.get("house_load_w") is not None:
        house_power_kw = float(current.get("house_load_w") or 0.0) / 1000.0

    # Wallbox-Informationen aus der Konfiguration auslesen
    config = app_state.get("config", {})
    adapters = config.get("adapters", {}) or {}
    wallbox_entries = {
        k: v
        for k, v in adapters.items()
        if (v.get("type") or "").lower().find("wallbox") != -1
    }

    selected_id: Optional[str] = None
    if wallbox_id and wallbox_id in wallbox_entries:
        selected_id = wallbox_id
    elif wallbox_entries:
        # Fallback: erste gefundene Wallbox nutzen
        selected_id = next(iter(wallbox_entries.keys()))

    dev = wallbox_entries.get(selected_id) if selected_id else None
    wallbox_present = bool(wallbox_entries)
    wallbox_enabled = bool(dev.get("enabled", True)) if dev else False
    v2h_capable = bool(dev.get("v2h_capable", False)) if dev else False
    # Ohne direkten Live-Status aus der Wallbox setzen wir "online" konservativ
    # gleich "enabled" – das Frontend nutzt dies vor allem für UI-Hinweise.
    wallbox_online = wallbox_enabled

    return {
        "active": active,
        "power_kw": round(power_kw, 3),
        "house_power_kw": round(house_power_kw, 3) if house_power_kw is not None else None,
        "error": None,
        "wallbox_present": wallbox_present,
        "wallbox_enabled": wallbox_enabled,
        "wallbox_online": wallbox_online,
        "preferred_wallbox_id": selected_id,
        "v2h_capable": v2h_capable,
    }



# --- /ev/profiles endpoint supporting GET, POST (save), PUT (activate), DELETE (delete) ---
from fastapi import Request, Body
from fastapi.responses import JSONResponse
import copy

@app.api_route("/ev/profiles", methods=["GET", "POST", "PUT", "DELETE"])
async def ev_profiles_endpoint(request: Request, body: dict = Body(None)):
    """
    GET: Returns all EV profiles from config.yaml.
    POST: Save (create/update) an EV profile. Expects {"id": ..., "profile": {...}}.
    PUT: Activate an EV profile. Expects {"id": ...}.
    DELETE: Delete an EV profile. Expects {"id": ...}.
    """
    config = app_state["config"]
    ev_profiles = config.get("ev_profiles", {})
    method = request.method

    if method == "GET":
        # Return both ev_profiles and active_ev_id for frontend compatibility
        active_ev_id = config.get("active_ev_id")
        return {"ev_profiles": ev_profiles, "active_ev_id": active_ev_id}

    if method == "POST":
        # Save (create/update) an EV profile
        data = body or await request.json()
        ev_id = data.get("id")
        profile = data.get("profile")
        if not ev_id or not profile:
            return JSONResponse(status_code=400, content={"error": "Missing 'id' or 'profile' in request."})
        ev_profiles[ev_id] = profile
        app_state["config"]["ev_profiles"] = ev_profiles
        # Optionally persist to config.yaml
        _persist_config(app_state["config"])
        return {"status": "saved", "ev_profiles": ev_profiles}


    if method == "PUT":
        # Activate an EV profile (set 'active' flag, deactivate others)
        data = body or await request.json()
        ev_id = data.get("id")
        def normalize(s):
            return str(s).replace(" ", "").replace("_", "").replace("-", "").lower()
        if not ev_id:
            # If no id is given, deactivate all profiles
            for k in ev_profiles:
                ev_profiles[k]["active"] = False
            app_state["config"]["ev_profiles"] = ev_profiles
            _persist_config(app_state["config"])
            return {"status": "deactivated_all", "active_id": None, "ev_profiles": ev_profiles}
        norm_ev_id = normalize(ev_id)
        match_id = None
        for k in ev_profiles:
            if normalize(k) == norm_ev_id:
                match_id = k
                break
        if not match_id:
            return JSONResponse(status_code=404, content={"error": "Profile not found."})
        # Deactivate all, activate one
        for k in ev_profiles:
            ev_profiles[k]["active"] = (k == match_id)
        app_state["config"]["ev_profiles"] = ev_profiles
        _persist_config(app_state["config"])
        return {"status": "activated", "active_id": match_id, "ev_profiles": ev_profiles}


    if method == "DELETE":
        # Delete an EV profile
        data = body or await request.json()
        ev_id = data.get("id")
        if not ev_id:
            return JSONResponse(status_code=404, content={"error": "Profile not found."})
        # Robust matching: case-insensitive, ignore spaces, underscores, hyphens
        def normalize(s):
            return str(s).replace(" ", "").replace("_", "").replace("-", "").lower()
        norm_ev_id = normalize(ev_id)
        match_id = None
        for k in ev_profiles:
            if normalize(k) == norm_ev_id:
                match_id = k
                break
        if not match_id:
            return JSONResponse(status_code=404, content={"error": "Profile not found."})
        del ev_profiles[match_id]
        app_state["config"]["ev_profiles"] = ev_profiles
        _persist_config(app_state["config"])
        return {"status": "deleted", "ev_profiles": ev_profiles}

    return JSONResponse(status_code=405, content={"error": "Method not allowed."})

# Helper to persist config to YAML
import yaml
import threading
def _persist_config(config):
    try:
        with threading.Lock():
            with open(os.path.join(os.path.dirname(__file__), '../config/config.yaml'), 'w') as f:
                yaml.safe_dump(config, f, allow_unicode=True)
    except Exception as e:
        print(f"[ERROR] Failed to persist config: {e}")

