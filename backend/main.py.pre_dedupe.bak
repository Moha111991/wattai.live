from fastapi import WebSocket, WebSocketDisconnect, APIRouter, Body
import asyncio, random
from datetime import datetime, timedelta
from typing import List, Dict, Any

import os, yaml
from fastapi import HTTPException, Query

from backend.services.state import RealtimeState
from backend.services.influx_service import create_influx_writer
from backend.mqtt_service import run_mqtt_loop, mqtt_publish
from backend.models.battery import BatterySimulator, BatteryConfig
from backend.controllers.v2h_controller import V2HController
from backend.adapters.base import DeviceAdapter
from backend.adapters.wallbox_goe import GoEWallboxAdapter
from backend.adapters.inverter_fronius import FroniusInverterAdapter
from backend.services.recommendation_service import generate_recommendation
from .config_service import load_config
from backend.routes.smartmeter import router as smartmeter_router

# Periodischer KI-Steuerungs-Task
async def ai_control_loop():
    from backend.ai_controller import get_ai_controller
    while True:
        try:
            controller = await get_ai_controller()
            # Hole aktuelle Systemdaten (Dummy, hier anpassen für echte Daten)
            current_data = {
                'pv_power': state.get_value('pv_power_kw', 0),
                'battery_soc': state.get_value('home_battery_soc', 0),
                'ev_soc': state.get_value('ev_soc', 0),
                'household_load': state.get_value('house_load_kw', 1.0),
                'grid_price': 0.28,
                'hour': datetime.now().hour,
                'temperature': 20
            }
            action = await controller.get_optimal_action(current_data)
            # Sende Steuerbefehle an Adapter (hier als Beispiel MQTT)
            mqtt_publish('energy/control', action)
            print(f"[KI] Steuerung ausgeführt: {action['explanation']}")
        except Exception as e:
            print(f"[KI] Fehler im Steuerungs-Loop: {e}")
        await asyncio.sleep(300)  # alle 5 Minuten

@app.on_event("startup")
async def startup_event():
    import redis.asyncio as aioredis
    redis = await aioredis.from_url("redis://localhost")  # Keep as is for local Redis
    await FastAPILimiter.init(redis)
    # Disabled AI control loop to prevent backend crash during debugging
    # asyncio.create_task(ai_control_loop())

state = RealtimeState()
battery = BatterySimulator(BatteryConfig())
v2h_controller = V2HController(battery)
influx_writer = None
clients: List[WebSocket] = []
mobile_clients = []
app_state = {"config": load_config()}


