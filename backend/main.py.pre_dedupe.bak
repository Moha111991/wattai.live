from backend.routes.alarms import router as alarms_router

from fastapi import WebSocket
# EV Runtime Vars (für /ws/mobile updates)
clients: list = []

# Minimal /ws WebSocket endpoint for dashboard/mobile
@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    await websocket.accept()
    clients.append(websocket)
    try:
        await websocket.send_json({"message": "WebSocket connection established"})
        while True:
            await websocket.receive_text()
    except Exception:
        pass
    finally:
        if websocket in clients:
            clients.remove(websocket)
