@limiter.limit("120/minute")
async def update_grid_realtime(request: Request, data: GridRealtimeData):
    """
    ⚡ Grid Import/Export Echtzeitdaten
    
    Empfängt aktuellen Netzbezug oder Einspeisung vom Stromzähler.
    Positiv = Import (Bezug), Negativ = Export (Einspeisung)
    """
    global current_grid_data
    
    if data.data_type == "import":
        current_grid_data["import_w"] = abs(data.power)
    elif data.data_type == "export":
        current_grid_data["export_w"] = abs(data.power)
    
    # TODO: Save to database for timeseries analysis
    # Currently using in-memory storage for MVP
    
    return {
        "status": "ok",
        "grid_import_w": current_grid_data["import_w"],
        "grid_export_w": current_grid_data["export_w"],
        "timestamp": datetime.now().isoformat()
    }

