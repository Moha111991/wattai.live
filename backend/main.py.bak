@app.get("/v2h/status")
async def v2h_status(wallbox_id: Optional[str] = Query(None)):
    """Gibt den aktuellen V2H-Status zurück.

    Diese Struktur ist auf das Frontend `ElektroautoV2H` abgestimmt und enthält
    neben Aktiv-Status und Leistung auch Metadaten zur (optionalen) Wallbox.
    """
    current = await state.get()

    # Basisleistungswerte aus dem Realtime-State ableiten
    active = bool(current.get("ev_v2h") is True)
    ev_power_w = float(current.get("ev_power_w") or 0.0)
    power_kw = ev_power_w / 1000.0

    house_power_kw: Optional[float] = None
    if current.get("house_load_w") is not None:
        house_power_kw = float(current.get("house_load_w") or 0.0) / 1000.0

    # Wallbox-Informationen aus der Konfiguration auslesen
    config = app_state.get("config", {})
    adapters = config.get("adapters", {}) or {}
    wallbox_entries = {
        k: v
        for k, v in adapters.items()
        if (v.get("type") or "").lower().find("wallbox") != -1
    }

    selected_id: Optional[str] = None
    if wallbox_id and wallbox_id in wallbox_entries:
        selected_id = wallbox_id
    elif wallbox_entries:
        # Fallback: erste gefundene Wallbox nutzen
        selected_id = next(iter(wallbox_entries.keys()))

    dev = wallbox_entries.get(selected_id) if selected_id else None
    wallbox_present = bool(wallbox_entries)
    wallbox_enabled = bool(dev.get("enabled", True)) if dev else False
    v2h_capable = bool(dev.get("v2h_capable", False)) if dev else False
    # Ohne direkten Live-Status aus der Wallbox setzen wir "online" konservativ
    # gleich "enabled" – das Frontend nutzt dies vor allem für UI-Hinweise.
    wallbox_online = wallbox_enabled

    return {
        "active": active,
        "power_kw": round(power_kw, 3),
        "house_power_kw": round(house_power_kw, 3) if house_power_kw is not None else None,
        "error": None,
        "wallbox_present": wallbox_present,
        "wallbox_enabled": wallbox_enabled,
        "wallbox_online": wallbox_online,
        "preferred_wallbox_id": selected_id,
        "v2h_capable": v2h_capable,
    }



# --- /ev/profiles endpoint supporting GET, POST (save), PUT (activate), DELETE (delete) ---
from fastapi import Request, Body
from fastapi.responses import JSONResponse
import copy

@app.api_route("/ev/profiles", methods=["GET", "POST", "PUT", "DELETE"])
async def ev_profiles_endpoint(request: Request, body: dict = Body(None)):
    """
    GET: Returns all EV profiles from config.yaml.
    POST: Save (create/update) an EV profile. Expects {"id": ..., "profile": {...}}.
    PUT: Activate an EV profile. Expects {"id": ...}.
    DELETE: Delete an EV profile. Expects {"id": ...}.
    """
    config = app_state["config"]
    ev_profiles = config.get("ev_profiles", {})
    method = request.method

    if method == "GET":
        # Return both ev_profiles and active_ev_id for frontend compatibility
        active_ev_id = config.get("active_ev_id")
        return {"ev_profiles": ev_profiles, "active_ev_id": active_ev_id}

    if method == "POST":
        # Save (create/update) an EV profile
        data = body or await request.json()
        ev_id = data.get("id")
        profile = data.get("profile")
        if not ev_id or not profile:
            return JSONResponse(status_code=400, content={"error": "Missing 'id' or 'profile' in request."})
        ev_profiles[ev_id] = profile
        app_state["config"]["ev_profiles"] = ev_profiles
        # Optionally persist to config.yaml
        _persist_config(app_state["config"])
        return {"status": "saved", "ev_profiles": ev_profiles}


    if method == "PUT":
        # Activate an EV profile (set 'active' flag, deactivate others)
        data = body or await request.json()
        ev_id = data.get("id")
        def normalize(s):
            return str(s).replace(" ", "").replace("_", "").replace("-", "").lower()
        if not ev_id:
            # If no id is given, deactivate all profiles
            for k in ev_profiles:
                ev_profiles[k]["active"] = False
            app_state["config"]["ev_profiles"] = ev_profiles
            _persist_config(app_state["config"])
            return {"status": "deactivated_all", "active_id": None, "ev_profiles": ev_profiles}
        norm_ev_id = normalize(ev_id)
        match_id = None
        for k in ev_profiles:
            if normalize(k) == norm_ev_id:
                match_id = k
                break
        if not match_id:
            return JSONResponse(status_code=404, content={"error": "Profile not found."})
        # Deactivate all, activate one
        for k in ev_profiles:
            ev_profiles[k]["active"] = (k == match_id)
        app_state["config"]["ev_profiles"] = ev_profiles
        _persist_config(app_state["config"])
        return {"status": "activated", "active_id": match_id, "ev_profiles": ev_profiles}


    if method == "DELETE":
        # Delete an EV profile
        data = body or await request.json()
        ev_id = data.get("id")
        if not ev_id:
            return JSONResponse(status_code=404, content={"error": "Profile not found."})
        # Robust matching: case-insensitive, ignore spaces, underscores, hyphens
        def normalize(s):
            return str(s).replace(" ", "").replace("_", "").replace("-", "").lower()
        norm_ev_id = normalize(ev_id)
        match_id = None
        for k in ev_profiles:
            if normalize(k) == norm_ev_id:
                match_id = k
                break
        if not match_id:
            return JSONResponse(status_code=404, content={"error": "Profile not found."})
        del ev_profiles[match_id]
        app_state["config"]["ev_profiles"] = ev_profiles
        _persist_config(app_state["config"])
        return {"status": "deleted", "ev_profiles": ev_profiles}

    return JSONResponse(status_code=405, content={"error": "Method not allowed."})

# Helper to persist config to YAML
import yaml
import threading
def _persist_config(config):
    try:
        with threading.Lock():
            with open(os.path.join(os.path.dirname(__file__), '../config/config.yaml'), 'w') as f:
                yaml.safe_dump(config, f, allow_unicode=True)
    except Exception as e:
        print(f"[ERROR] Failed to persist config: {e}")

