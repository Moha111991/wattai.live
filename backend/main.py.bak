@app.post("/safety/reset")
@limiter.limit("5/minute")
async def safety_reset(
    request: Request,
    manual_override: bool = False,
    _: None = Depends(verify_api_key)
):
    """
    🔄 Reset from Safe State
    
    Setzt System von SAFE_STATE zurück zu NORMAL.
    
    ⚠️ **Requires manual_override=true** for safety!
    
    **Cannot reset from EMERGENCY_STOP** (requires system restart).
    """
    if not SAFETY_ENABLED:
        raise HTTPException(status_code=503, detail="Safety Layer not available")
    
    try:
        safety = get_safety_monitor()
        
        if not manual_override:
            raise HTTPException(
                status_code=400,
                detail="Manual override required. Set manual_override=true to confirm reset."
            )
        
        success = safety.reset_safe_state(manual_override=True)
        
        if not success:
            return {
                "status": "failed",
                "message": "Reset failed - EMERGENCY_STOP requires system restart",
                "current_state": safety.safety_state.value,
                "timestamp": datetime.now().isoformat()
            }
        
        return {
            "status": "success",
            "message": "System reset to NORMAL state",
            "current_state": safety.safety_state.value,
            "timestamp": datetime.now().isoformat()
        }
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/safety/watchdog")
@limiter.limit("60/minute")
async def safety_watchdog(request: Request):
    """
    ⏱️ Watchdog & Component Status
    
    Zeigt Status aller überwachten Komponenten.
    
    **Components:**
    - soc_updater
    - control_endpoint
    - ai_controller
    - mqtt_bridge
    """
    if not SAFETY_ENABLED:
        raise HTTPException(status_code=503, detail="Safety Layer not available")
    
    try:
        safety = get_safety_monitor()
        component_status = safety.get_component_status()
        
        return {
            "status": "success",
            "watchdog_timeout_sec": safety.watchdog_timeout,
            "components": component_status,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))








