@app.post("/control", dependencies=[Depends(verify_api_key)])
@limiter.limit("10/minute")
async def send_control_command(request: Request, command: ControlCommand):
    """
    🎮 Manueller Steuerungsbefehl
    
    Sendet direkten Befehl an Geräte (EV, Batterie, Wallbox)
    
    ⚠️ ISO 26262 SAFETY: Command validation enabled
    """
    # ISO 26262 Safety Checks
    if SAFETY_ENABLED:
        safety = get_safety_monitor()
        safety.heartbeat("control_endpoint")
        
        # Check 1: Is system in safe state?
        if safety.safety_state == SafetyState.SAFE_STATE:
            raise HTTPException(
                status_code=503,
                detail="System in Safe State - manual reset required. No commands allowed."
            )
        
        if safety.safety_state == SafetyState.EMERGENCY_STOP:
            raise HTTPException(
                status_code=503,
                detail="EMERGENCY STOP active - system restart required"
            )
        
        # Check 2: Validate command
        if not safety.validate_command(command.device_type, command.command):
            raise HTTPException(
                status_code=400,
                detail=f"Safety violation: Command '{command.command}' for {command.device_type} rejected"
            )
    
    try:
        # Hier würden die Device Adapters integriert werden
        # Beispiel-Implementierung:
        
        return {
            "status": "success",
            "message": f"Befehl '{command.command}' an {command.device_type} gesendet",
            "device_type": command.device_type,
            "command": command.command,
            "params": command.params,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

class ISO15118SessionRequest(BaseModel):
    ev_id: str
    evse_id: str
    protocol: str = "ISO_15118_2"
    energy_mode: str = "AC_three_phase"
    auth_mode: str = "EIM"
    
    @validator('protocol')
    def validate_protocol(cls, v):
        valid_protocols = ["DIN_70121", "ISO_15118_2", "ISO_15118_20"]
        if v not in valid_protocols:
            raise ValueError(f"Invalid protocol. Must be one of: {valid_protocols}")
        return v
    
    @validator('energy_mode')
    def validate_energy_mode(cls, v):
        valid_modes = ["AC_single_phase", "AC_three_phase", "DC_core", "DC_extended", "DC_combo"]
        if v not in valid_modes:
            raise ValueError(f"Invalid energy_mode. Must be one of: {valid_modes}")
        return v
    
    @validator('auth_mode')
    def validate_auth_mode(cls, v):
        valid_modes = ["EIM", "PnC"]
        if v not in valid_modes:
            raise ValueError(f"Invalid auth_mode. Must be one of: {valid_modes}")
        return v

class ISO15118AuthRequest(BaseModel):
    session_id: str
    contract_id: Optional[str] = None

class ISO15118ChargingProfileRequest(BaseModel):
    session_id: str
    battery_capacity: float
    current_soc: float
    target_soc: float
    pv_forecast: List[float]
    grid_prices: List[float]
    departure_time: Optional[str] = None
    
    @validator('battery_capacity')
    def validate_battery_capacity(cls, v):
        if not (10.0 <= v <= 300.0):
            raise ValueError("battery_capacity must be between 10.0 and 300.0 kWh")
        return v
    
    @validator('current_soc', 'target_soc')
    def validate_soc(cls, v):
        if not (0.0 <= v <= 100.0):
            raise ValueError("SOC must be between 0 and 100")
        return v

class ISO15118PowerDeliveryRequest(BaseModel):
    session_id: str
    charge_progress: bool = True

class ISO15118ChargingStatusRequest(BaseModel):
    session_id: str
    current_soc: float
    charging_current: float
    charging_voltage: float
    
    @validator('current_soc')
    def validate_soc(cls, v):
        if not (0.0 <= v <= 100.0):
            raise ValueError("SOC must be between 0 and 100")
        return v
    
    @validator('charging_current')
    def validate_current(cls, v):
        if not (0.0 <= v <= 500.0):
            raise ValueError("charging_current must be between 0 and 500 A")
        return v
    
    @validator('charging_voltage')
    def validate_voltage(cls, v):
        if not (0.0 <= v <= 1000.0):
            raise ValueError("charging_voltage must be between 0 and 1000 V")
        return v

class ISO15118SessionStopRequest(BaseModel):
    session_id: str

@app.post("/iso15118/session")
@limiter.limit("20/minute")
async def iso15118_session_setup(
    request: Request,
    data: ISO15118SessionRequest,
    _: None = Depends(verify_api_key)
):
    """
    🔌 ISO 15118 Session Setup
    
    Etabliert V2G-Session zwischen EV und Ladepunkt
    """
    if not ISO15118_ENABLED:
        raise HTTPException(status_code=503, detail="ISO 15118 not available")
    
    try:
        session = await iso15118_handler.session_setup(
            ev_id=data.ev_id,
            evse_id=data.evse_id,
            protocol=ISO15118Protocol(data.protocol),
            energy_mode=EnergyTransferMode(data.energy_mode),
            auth_mode=AuthMode(data.auth_mode)
        )
        
        return {
            "status": "success",
            "session": session.dict(),
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/iso15118/authorize")
@limiter.limit("20/minute")
async def iso15118_authorize(
    request: Request,
    data: ISO15118AuthRequest,
    _: None = Depends(verify_api_key)
):
    """
    🔐 Plug & Charge Authorization
    
    Authentifiziert EV für Ladung (EIM oder Plug & Charge)
    """
    if not ISO15118_ENABLED:
        raise HTTPException(status_code=503, detail="ISO 15118 not available")
    
    try:
        authorized = await iso15118_handler.authorize_payment(data.session_id, data.contract_id)
        
        return {
            "status": "success" if authorized else "failed",
            "session_id": data.session_id,
            "authorized": authorized,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/iso15118/charging-profile")
@limiter.limit("10/minute")
async def iso15118_create_charging_profile(
    request: Request,
    data: ISO15118ChargingProfileRequest,
    _: None = Depends(verify_api_key)
):
    """
    📊 Smart Charging Profile erstellen
    
    Optimiert Ladeplan basierend auf PV-Überschuss, Strompreisen und Departure Time
    """
    if not ISO15118_ENABLED:
        raise HTTPException(status_code=503, detail="ISO 15118 not available")
    
    try:
        # Charge Parameter Discovery
        params = await iso15118_handler.charge_parameter_discovery(
            session_id=data.session_id,
            battery_capacity=data.battery_capacity,
            current_soc=data.current_soc,
            target_soc=data.target_soc,
            departure_time=datetime.fromisoformat(data.departure_time) if data.departure_time else None
        )
        
        # Smart Charging Profile
        profile = await iso15118_handler.create_smart_charging_profile(
            session_id=data.session_id,
            pv_forecast=data.pv_forecast,
            grid_prices=data.grid_prices
        )
        
        return {
            "status": "success",
            "parameters": params,
            "charging_profile": profile.dict(),
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

