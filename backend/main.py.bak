# Global storage für PV/Grid Echtzeitdaten (in-memory für Live-Anzeige)
current_pv_data: Dict[str, float] = {"power_w": 0.0, "yield_kwh": 0.0}
current_grid_data: Dict[str, float] = {"import_w": 0.0, "export_w": 0.0}
inverter_status_data: Dict[str, any] = {"status": "unknown", "temperature": 0.0, "efficiency": 0.0}

@app.post("/pv/realtime", dependencies=[Depends(verify_api_key)])
@limiter.limit("120/minute")
async def update_pv_realtime(request: Request, data: PVRealtimeData):
    """
    ☀️ PV-Echtzeitdaten empfangen (von MQTT Bridge)
    
    Empfängt aktuelle PV-Leistung und Tagesertrag vom Wechselrichter.
    Wird automatisch über MQTT Topic 'ems/pv/power' oder 'ems/pv/yield' aktualisiert.
    
    Architecture:
    PV-Inverter → Edge Gateway (Modbus/SunSpec) → MQTT → EMS Backend
    """
    global current_pv_data
    
    if data.power is not None:
        current_pv_data["power_w"] = data.power
    if data.yield_today is not None:
        current_pv_data["yield_kwh"] = data.yield_today
    
    # TODO: Save to database for timeseries analysis
    # Currently using in-memory storage for MVP
    # Database persistence will be added in future iteration
    
    # WebSocket Broadcast an Mobile App
    failed_clients = []
    for client in clients:
        try:
            await client.send_json({
                "type": "pv_realtime",
                "power_w": current_pv_data["power_w"],
                "yield_kwh": current_pv_data["yield_kwh"],
                "timestamp": datetime.now().isoformat()
            })
        except:
            failed_clients.append(client)
    
    for client in failed_clients:
        if client in clients:
            clients.remove(client)
    
    return {
        "status": "ok",
        "pv_power_w": current_pv_data["power_w"],
        "pv_yield_kwh": current_pv_data["yield_kwh"],
        "timestamp": datetime.now().isoformat()
    }

@app.get("/pv/realtime")
async def get_pv_realtime():
    """
    ☀️ Aktuelle PV-Echtzeitdaten abrufen
    
    Gibt die zuletzt empfangenen PV-Werte zurück.
    """
    return {
        "power_w": current_pv_data["power_w"],
        "power_kw": current_pv_data["power_w"] / 1000.0,
        "yield_today_kwh": current_pv_data["yield_kwh"],
        "timestamp": datetime.now().isoformat()
    }

