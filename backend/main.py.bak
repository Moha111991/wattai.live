# Adapter, die nicht explizit in config.yaml definiert sind, aber
# Messdaten an /api/ingest senden, werden hier zur Laufzeit gesammelt.
# Diese Liste wird mit den statischen Adaptern zusammengeführt, wenn
# das Frontend /devices abfragt.
dynamic_adapters: Dict[str, Dict[str, Any]] = {}

# Zuordnung für Verbindungsversuche aus dem UI ("Gerät verbinden")
# auf Basis einer fachlichen Request-ID. Damit kann das Frontend
# optional einen konkreten Connect-Versuch verfolgen.
pending_connections: Dict[str, Dict[str, Any]] = {}


# --- Devices and EV Profiles Endpoints ---
from fastapi import Response

@app.get("/devices")
async def get_devices():
    """Liefert Geräte aus config.yaml *und* dynamisch entdeckte Adapter.

    - Statische Adapter: ``config.yaml -> adapters``
    - Dynamische Adapter: werden über ``POST /api/ingest`` registriert,
      wenn ein unbekannter ``device_id``/``device`` gemeldet wird.
    """
    config = app_state["config"]
    adapters = config.get("adapters", {}) or {}

    # Statische Geräte aus config.yaml
    devices = [dict(id=k, **v) for k, v in adapters.items()]

    # Dynamisch registrierte Adapter ergänzen (ohne Duplikate)
    for dev_id, meta in dynamic_adapters.items():
        if not any(d.get("id") == dev_id for d in devices):
            devices.append(meta)

    return {"devices": devices}


@app.get("/devices/{device_id}/details")
async def get_device_details(device_id: str):
  """Liefert Detailstatus für ein Gerät.

  Aktuell ist nur ein sinnvoller Laufzeitstatus für Wallboxen (z.B. go-eCharger)
  implementiert. Für andere Gerätetypen wird eine einfache Stub-Antwort
  mit Basisinformationen zurückgegeben.
  """
  config = app_state.get("config", {})
  adapters = config.get("adapters", {}) or {}
  dev = adapters.get(device_id)
  if not dev:
      raise HTTPException(status_code=404, detail="Device not found")

  dev_type = (dev.get("type") or "").lower()

  # Nur für Wallboxen versuchen wir, einen echten Status per HTTP abzufragen.
  if dev_type != "wallbox":
      return {
          "device_id": device_id,
          "type": dev.get("type"),
          "online": False,
          "status": "unsupported",
          "ev_connected": False,
          "connector_locked": False,
          "power_kw": 0.0,
          "soc": None,
          "v2h_ready": bool(dev.get("v2h_capable", False)),
          "error": "Status-Endpunkt ist derzeit nur für Wallboxen implementiert.",
      }

  host = dev.get("ip") or dev.get("host")
  if not host:
      return {
          "device_id": device_id,
          "type": dev.get("type"),
          "online": False,
          "status": "config_error",
          "ev_connected": False,
          "connector_locked": False,
          "power_kw": 0.0,
          "soc": None,
          "v2h_ready": bool(dev.get("v2h_capable", False)),
          "error": "Keine IP/Host für Wallbox in der Konfiguration hinterlegt.",
      }

  try:
      async with httpx.AsyncClient(timeout=5) as client:
          r = await client.get(f"http://{host}/api/status")
          r.raise_for_status()
          data = r.json()
  except Exception as e:
      return {
          "device_id": device_id,
          "type": dev.get("type"),
          "online": False,
          "status": "offline",
          "ev_connected": False,
          "connector_locked": False,
          "power_kw": 0.0,
          "soc": None,
          "v2h_ready": bool(dev.get("v2h_capable", False)),
          "error": f"Fehler bei Statusabfrage der Wallbox: {e}",
      }

  # go-e spezifische Auswertung
  car_state = data.get("car", 0)
  # einfache Heuristik: car_state > 0 bedeutet Fahrzeug erkannt/angeschlossen
  ev_connected = car_state in (1, 2, 3, 4)
  charging_state_map = {1: "ready", 2: "charging", 3: "waiting", 4: "done"}
  charging_state = charging_state_map.get(car_state, "unknown")

  nrg = data.get("nrg", [0] * 16)
  power_w = nrg[11] if len(nrg) > 11 else 0
  power_kw = round(float(power_w) / 1000.0, 3)

  soc = data.get("soc")

  # V2H-Bereitschaft: hängt von Konfiguration und angeschlossenem Fahrzeug ab.
  v2h_ready = bool(dev.get("v2h_capable", False) and ev_connected)

  return {
      "device_id": device_id,
      "type": dev.get("type"),
      "online": True,
      "status": charging_state,
      "ev_connected": ev_connected,
      # Konnektorverriegelung: hier vereinfachend gleichgesetzt mit "Fahrzeug erkannt".
      "connector_locked": ev_connected,
      "power_kw": power_kw,
      "soc": soc,
      "v2h_ready": v2h_ready,
      "error": None,
  }



@app.post("/devices/{device_id}/connect")
async def connect_device(device_id: str, payload: Dict[str, Any] = Body(None)):
    """Startet einen Verbindungsversuch für ein Gerät.

    Das Frontend kann optional eine ``request_id`` mitsenden. Falls keine
    angegeben wird, generiert das Backend eine neue UUID.

    Die so erzeugte Request-ID kann genutzt werden, um den Status eines
    bestimmten "Gerät verbinden"-Klicks fachlich nachzuverfolgen.
    """
    from datetime import datetime

    body: Dict[str, Any] = payload or {}
    request_id = body.get("request_id") or str(uuid4())

    pending_connections[request_id] = {
        "device_id": device_id,
        "status": "pending",
        "created_at": datetime.utcnow().isoformat(),
        "params": body,
    }

    # Broadcast pending state to websocket clients (best-effort)
    try:
        asyncio.create_task(broadcast_connection_event({
            "type": "connection_update",
            "request_id": request_id,
            "status": "pending",
            "device_id": device_id,
            "created_at": pending_connections[request_id]["created_at"],
        }))
    except Exception:
        pass

    return {"request_id": request_id, "status": "pending"}


@app.get("/connections/{request_id}")
async def get_connection_status(request_id: str):
    """Gibt den Status eines Verbindungsversuchs anhand der Request-ID zurück."""
    info = pending_connections.get(request_id)
    if not info:
        raise HTTPException(status_code=404, detail="Connection not found")
    return info


@app.get("/smartmeter/energy")
async def smartmeter_energy():
    """Aggregierte Energiewerte des Smart Meters.

    Die Daten stammen aus dem zentralen `RealtimeState`, der u.a. über `mqtt_service`
    aus den Topics `energy/smartmeter/import_kwh` und `energy/smartmeter/export_kwh`
    gespeist wird. Das Frontend erwartet folgende Struktur:

    {
      "import_kwh": number | null,
      "export_kwh": number | null,
      "power_w": number | null,
      "voltage_v": number | null,
      "current_a": number | null,
      "energy_today_kwh": number | null,
      "energy_total_kwh": number | null
    }

    Nicht vorhandene Werte werden als null zurückgegeben, damit das Frontend
    sie robust mit "-" darstellen kann.
    """
    current = await state.get()

    import_kwh = current.get("smartmeter_import_kwh")
    export_kwh = current.get("smartmeter_export_kwh")

    # Versuche eine sinnvolle Leistungsableitung: bevorzugt Netzübergang,
    # ansonsten Hauslast, falls vorhanden.
    power_w: Optional[float] = None
    grid_import_w = current.get("grid_import_w")
    grid_export_w = current.get("grid_export_w")
    house_load_w = current.get("house_load_w")

    if grid_import_w is not None or grid_export_w is not None:
        power_w = float(grid_import_w or 0.0) - float(grid_export_w or 0.0)
    elif house_load_w is not None:
        power_w = float(house_load_w or 0.0)

    return {
        "import_kwh": import_kwh,
        "export_kwh": export_kwh,
        "power_w": power_w,
        # Diese Felder sind optional und können später durch Erweiterung
        # des MQTT-Adapters/States mit echten Werten befüllt werden.
        "voltage_v": None,
        "current_a": None,
        "energy_today_kwh": None,
        "energy_total_kwh": None,
    }


