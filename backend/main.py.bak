@app.post("/ai/decision")
@limiter.limit("20/minute")
async def get_ai_decision(request: Request, system_data: SystemData):
    """
    🤖 AI-Entscheidung für aktuelle Situation
    
    Gibt optimale Steuerungsempfehlung basierend auf:
    - Aktuellem PV-Ertrag
    - SOC von EV und Batterie
    - Grid-Preis
    - Tageszeit
    """
    try:
        controller = await get_ai_controller()
        decision = await controller.get_optimal_action(system_data.dict())
        
        return {
            "status": "success",
            "decision": decision,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/ai/optimize")
@limiter.limit("5/minute")
async def optimize_schedule(request: Request, forecast_data: List[SystemData], horizon_hours: int = 24):
    """
    📊 24h-Energieplanung optimieren
    
    Erstellt optimalen Lade-/Entlade-Plan für die nächsten X Stunden
    """
    try:
        controller = await get_ai_controller()
        schedule = await controller.optimize_schedule(
            [data.dict() for data in forecast_data],
            horizon_hours
        )
        
        return {
            "status": "success",
            "schedule": schedule,
            "horizon_hours": horizon_hours,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

