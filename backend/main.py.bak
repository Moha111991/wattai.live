async def verify_api_key(x_api_key: str = Header(None)):
    """Optionale API-Key-Authentifizierung (nur wenn API_KEY_ENABLED=true)"""
    if not API_KEY_ENABLED:
        return True
    
    if not x_api_key or x_api_key != API_KEY:
        raise HTTPException(
            status_code=403,
            detail="Invalid or missing API key. Please provide X-API-Key header."
        )
    return True

class SOCData(BaseModel):
    device: str
    soc: float
    
    @validator('device')
    def validate_device(cls, v):
        allowed = ['ev', 'home_battery']
        if v not in allowed:
            raise ValueError(f'Device must be one of {allowed}')
        return v
    
    @validator('soc')
    def validate_soc(cls, v):
        if not 0 <= v <= 100:
            raise ValueError('SOC must be between 0 and 100')
        return v

class PVRealtimeData(BaseModel):
    """PV-Echtzeitdaten von Wechselrichter/Zähler"""
    power: Optional[float] = None  # Aktuelle Leistung (W)
    yield_today: Optional[float] = None  # Tagesertrag (kWh)
    data_type: Optional[str] = "power"  # 'power' oder 'yield'
    
    @validator('power')
    def validate_power(cls, v):
        if v is not None and v < 0:
            raise ValueError('PV power must be non-negative')
        return v
    
    @validator('yield_today')
    def validate_yield(cls, v):
        if v is not None and v < 0:
            raise ValueError('Yield must be non-negative')
        return v

class GridRealtimeData(BaseModel):
    """Grid Import/Export Echtzeitdaten"""
    power: float  # Leistung (W), positiv = Import, negativ = Export
    data_type: str = "import"  # 'import' oder 'export'
    
    @validator('power')
    def validate_power(cls, v):
        if abs(v) > 100000:  # Max 100 kW
            raise ValueError('Grid power exceeds reasonable limits (100 kW)')
        return v

class InverterStatus(BaseModel):
    """Wechselrichter-Status"""
    status: str  # 'online', 'offline', 'fault'
    temperature: Optional[float] = None  # Temperatur (°C)
    efficiency: Optional[float] = None  # Wirkungsgrad (%)
    
    @validator('status')
    def validate_status(cls, v):
        allowed = ['online', 'offline', 'fault', 'standby']
        if v not in allowed:
            raise ValueError(f'Status must be one of {allowed}')
        return v

class SystemData(BaseModel):
    """Aktueller System-Zustand"""
    pv_power: float = 0.0
    battery_soc: float = 50.0
    ev_soc: float = 50.0
    household_load: float = 1.0
    grid_price: float = 0.28
    hour: int = 12
    temperature: float = 20.0
    ev_connected: bool = False
    
    @validator('battery_soc', 'ev_soc')
    def validate_soc_values(cls, v):
        if not 0 <= v <= 100:
            raise ValueError('SOC must be between 0 and 100')
        return v
    
    @validator('pv_power', 'household_load')
    def validate_power_values(cls, v):
        if v < 0:
            raise ValueError('Power values must be non-negative')
        return v
    
    @validator('hour')
    def validate_hour(cls, v):
        if not 0 <= v <= 23:
            raise ValueError('Hour must be between 0 and 23')
        return v

class ControlCommand(BaseModel):
    """Steuerungsbefehl"""
    device_type: str
    command: str
    params: Optional[Dict] = {}
    
    @validator('device_type')
    def validate_device_type(cls, v):
        # All device types supported by SafetyMonitor
        allowed = ['ev', 'battery', 'home_battery', 'wallbox', 'heat_pump']
        if v not in allowed:
            raise ValueError(f'Device type must be one of {allowed}')
        return v
    
    @validator('command')
    def validate_command(cls, v):
        # All commands supported by SafetyMonitor across all device types
        allowed = [
            # EV commands
            'start_charging', 'stop_charging', 'set_charge_limit',
            'set_charge_power', 'enable_v2g', 'disable_v2g',
            # Battery/Wallbox commands
            'discharge_to_grid', 'stop_discharge', 'set_current_limit',
            # Heat Pump commands
            'start_heating', 'stop_heating', 'start_cooling', 'stop_cooling',
        ]
        if v not in allowed:
            raise ValueError(f'Command must be one of {allowed}')
        return v

