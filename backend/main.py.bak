@app.websocket("/ws")
async def websocket_endpoint(ws: WebSocket):
    """WebSocket-Endpoint für Mobile App mit optionaler Authentifizierung"""
    
    if API_KEY_ENABLED:
        api_key = ws.query_params.get("x_api_key")
        if not api_key or api_key != API_KEY:
            await ws.close(code=1008, reason="Unauthorized: Invalid or missing API key")
            return
    
    await ws.accept()
    clients.append(ws)
    try:
        await ws.send_json({
            "device": "ev",
            "soc": current_soc_values.get("ev", 0.0)
        })
        await ws.send_json({
            "device": "home_battery",
            "soc": current_soc_values.get("home_battery", 0.0)
        })
        
        while True:
            await asyncio.sleep(1)
    except Exception:
        if ws in clients:
            clients.remove(ws)

@app.post("/update_soc", dependencies=[Depends(verify_api_key)])
@limiter.limit("60/minute")
async def update_soc(request: Request, data: SOCData):
    """
    MQTT-Bridge Updated SOC-Werte hier
    
    ⚠️ ISO 26262 SAFETY: SOC plausibility checks enabled
    """
    # ISO 26262 Safety Check
    if SAFETY_ENABLED:
        safety = get_safety_monitor()
        safety.heartbeat("soc_updater")
        
        if not safety.validate_soc(data.soc, data.device):
            raise HTTPException(
                status_code=400,
                detail=f"Safety violation: SOC value {data.soc}% rejected for {data.device}"
            )
    
    current_soc_values[data.device] = data.soc
    
    failed_clients = []
    for client in clients:
        try:
            await client.send_json({
                "soc": payload.soc,
                "timestamp": datetime.now().isoformat()
            })
        except Exception:
            failed_clients.append(client)
    
    for client in failed_clients:
        if client in clients:
            clients.remove(client)
    
    return {"status": "ok", "device": data.device, "soc": data.soc}

