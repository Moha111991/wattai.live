# ============================================================================
# EDGE-AI ENDPOINTS (KI-Modelle im Fahrzeug)
# ============================================================================

class EdgeAIDecisionRequest(BaseModel):
    """Request für Edge-AI Energieentscheidung"""
    ev_soc: float = 50.0
    battery_temp: float = 20.0
    pv_power: float = 0.0
    grid_price: float = 0.30
    co2_intensity: float = 300.0
    
    @validator('ev_soc')
    def validate_soc(cls, v):
        if not 0 <= v <= 100:
            raise ValueError('SOC must be between 0 and 100')
        return v

@app.post("/edge_ai/decision")
@limiter.limit("60/minute")
async def edge_ai_decision(
    request: Request,
    data: EdgeAIDecisionRequest,
    _: None = Depends(verify_api_key)
):
    """
    🤖 Autonome Energieentscheidung durch Edge-AI
    
    Das Fahrzeug trifft selbstständig Entscheidungen über Laden/Entladen
    basierend auf lokalem neuronalen Netz (TensorFlow Lite).
    
    Keine Cloud-Abhängigkeit - alle Berechnungen lokal im Fahrzeug!
    """
    if not EDGE_AI_ENABLED:
        raise HTTPException(status_code=503, detail="Edge-AI not available")
    
    try:
        agent = get_autonomous_agent()
        
        system_state = {
            'ev_soc': data.ev_soc,
            'battery_temp': data.battery_temp,
            'pv_power': data.pv_power,
            'grid_price': data.grid_price,
            'co2_intensity': data.co2_intensity
        }
        
        decision = agent.make_decision(system_state)
        
        return {
            "status": "success",
            "decision": decision,
            "mode": "edge_ai" if agent.model else "rule_based",
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/edge_ai/auto_decision")
@limiter.limit("120/minute")
async def edge_ai_auto_decision(request: Request, system_state: SystemData):
    """
    🤖🔄 AUTOMATISCHE Edge-AI Entscheidung (PV-getriggert)
    
    Dieser Endpoint wird automatisch getriggert wenn neue PV-Daten empfangen werden.
    Die KI bewertet die Situation und gibt Lade-/Entlade-Empfehlungen.
    
    **Trigger:** MQTT Bridge ruft dies auf bei `ems/pv/power` Messages
    
    **Automatische Steuerung basierend auf:**
    - ☀️ Echtzeitiger PV-Überschuss
    - 🔋 Aktueller EV SOC
    - 💰 Strompreis (falls vorhanden)
    - 🌡️ CO₂-Intensität
    
    **ISO 26262 Safety:** Command validation AKTIV
    """
    if not EDGE_AI_ENABLED:
        # Fallback zu regelbasierter Logik
        return {
            "status": "fallback",
            "decision": {
                "action": "idle",
                "power_kw": 0.0,
                "reasoning": "Edge-AI not available - no automatic action taken",
                "mode": "fallback"
            },
            "timestamp": datetime.now().isoformat()
        }
    
    try:
        # ISO 26262 Safety Check
        if SAFETY_ENABLED:
            safety = get_safety_monitor()
            safety.heartbeat("edge_ai_auto")
            
            if safety.safety_state != SafetyState.NORMAL:
                return {
                    "status": "safety_blocked",
                    "decision": {
                        "action": "idle",
                        "power_kw": 0.0,
                        "reasoning": f"System in {safety.safety_state.value} - no automatic actions allowed"
                    },
                    "timestamp": datetime.now().isoformat()
                }
        
        # Edge-AI Entscheidung
        agent = get_autonomous_agent()
        decision = agent.make_decision({
            "ev_soc": system_state.ev_soc,
            "battery_temp": system_state.temperature,
            "pv_power": system_state.pv_power,
            "grid_price": system_state.grid_price,
            "co2_intensity": 300.0  # Default
        })
        
        # Log für Debugging
        action = decision.get("action", "idle")
        power = decision.get("power_kw", 0.0)
        print(f"🤖 AUTO-DECISION: {action} ({power:.1f} kW) | PV: {system_state.pv_power:.1f} kW, SOC: {system_state.ev_soc:.0f}%")
        
        return {
            "status": "success",
            "decision": decision,
            "auto_triggered": True,
            "pv_power_kw": system_state.pv_power,
            "ev_soc": system_state.ev_soc,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/edge_ai/status")
@limiter.limit("60/minute")
async def edge_ai_status(request: Request):
    """
    📊 Status des Edge-AI Systems
    
    Zeigt ob TensorFlow Lite Modell geladen ist und einsatzbereit.
    """
    if not EDGE_AI_ENABLED:
        raise HTTPException(status_code=503, detail="Edge-AI not available")
    
    try:
        agent = get_autonomous_agent()
        
        model_loaded = agent.model is not None
        model_format = agent.model.model_format if model_loaded else None
        model_path = agent.model.model_path if model_loaded else None
        
        return {
            "status": "operational" if model_loaded else "fallback",
            "model_loaded": model_loaded,
            "model_format": model_format,
            "model_path": model_path,
            "mode": "edge_ai" if model_loaded else "rule_based",
            "capabilities": {
                "autonomous_charging": True,
                "pv_optimization": True,
                "cost_optimization": True,
                "co2_minimization": True,
                "v2g_capable": True
            },
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/edge_ai/history")
@limiter.limit("60/minute")
async def edge_ai_history(request: Request, limit: int = 10):
    """
    📜 Historie der autonomen Entscheidungen
    
    Zeigt die letzten Edge-AI Entscheidungen für Analyse und Debugging.
    """
    if not EDGE_AI_ENABLED:
        raise HTTPException(status_code=503, detail="Edge-AI not available")
    
    try:
        agent = get_autonomous_agent()
        history = agent.get_decision_history(limit=limit)
        
        return {
            "status": "success",
            "history": history,
            "count": len(history),
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/edge_ai/retrain")
@limiter.limit("5/hour")
async def edge_ai_retrain(
    request: Request,
    _: None = Depends(verify_api_key)
):
    """
    🔄 Modell neu trainieren (nur für Entwicklung)
    
    Trainiert das Edge-AI Modell neu mit synthetischen Daten.
    In Production würde hier echtes Fahrzeug-Feedback verwendet.
    
    ⚠️ ISO 21434 Security: Modell-Updates müssen signiert sein!
    """
    if not EDGE_AI_ENABLED:
        raise HTTPException(status_code=503, detail="Edge-AI not available")
    
    try:
        trainer = EdgeAIModelTrainer()
        trainer.create_model()
        history = trainer.train(epochs=30)
        
        # Export to TFLite
        model_path = trainer.export_tflite()
        
        return {
            "status": "success",
            "message": "Model retrained successfully",
            "model_path": model_path,
            "training_accuracy": float(history.history['accuracy'][-1]),
            "validation_accuracy": float(history.history['val_accuracy'][-1]),
            "epochs": len(history.history['accuracy']),
            "timestamp": datetime.now().isoformat(),
            "security_note": "⚠️ In production, model updates MUST be signed (ISO 21434)"
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


# ========================================================================
# TELEMETRIE ENDPOINTS (Federated Learning)
# ========================================================================

class TelemetryData(BaseModel):
    """Telemetrie-Daten von Fahrzeug"""
    ev_soc: float
    battery_soc: float
    pv_power: float
    grid_price: float
    action_taken: str
    reward: float
    cost: float
    co2: float
    autarky: float

@app.post("/telemetry/opt-in")
@limiter.limit("10/minute")
async def telemetry_opt_in(request: Request):
    """
    ✅ Telemetrie aktivieren (Nutzer-Opt-in)
    
    Aktiviert anonymisierte Daten-Sammlung für Federated Learning.
    
    **Datenschutz-Garantien:**
    - Keine persönlichen Daten oder Fahrzeug-IDs
    - Nur aggregierte Statistiken
    - Session-ID ändert sich bei Neustart
    - Jederzeit widerrufbar
    """
    if not TELEMETRY_ENABLED:
        raise HTTPException(status_code=503, detail="Telemetry not available")
    
    try:
        collector = get_telemetry_collector()
        collector.enable()
        
        return {
            "status": "success",
            "message": "Telemetrie aktiviert - Danke für Ihre Unterstützung!",
            "privacy_note": "Es werden nur anonymisierte, aggregierte Daten gesammelt",
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/telemetry/opt-out")
@limiter.limit("10/minute")
async def telemetry_opt_out(request: Request):
    """
    🚫 Telemetrie deaktivieren (Nutzer-Opt-out)
    
    Deaktiviert Telemetrie und löscht alle gesammelten Daten.
    """
    if not TELEMETRY_ENABLED:
        raise HTTPException(status_code=503, detail="Telemetry not available")
    
    try:
        collector = get_telemetry_collector()
        collector.disable()
        
        return {
            "status": "success",
            "message": "Telemetrie deaktiviert - Alle Daten wurden gelöscht",
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/telemetry/submit")
@limiter.limit("60/hour")
async def submit_telemetry(request: Request, data: TelemetryData):
    """
    📊 Telemetrie-Daten einreichen
    
    Fahrzeuge senden anonymisierte Entscheidungen zur Verbesserung der AI.
    
    **Privacy by Design:**
    - Automatische Anonymisierung
    - Kategorisierung statt Absolutwerte
    - Rate Limiting zum Schutz vor Tracking
    """
    if not TELEMETRY_ENABLED:
        raise HTTPException(status_code=503, detail="Telemetry not available")
    
    try:
        collector = get_telemetry_collector()
        
        if not collector.enabled:
            raise HTTPException(status_code=403, detail="Telemetry not enabled - User must opt-in first")
        
        # Record decision
        collector.record_decision(
            state={
                'ev_soc': data.ev_soc,
                'pv_power': data.pv_power,
                'grid_price': data.grid_price,
            },
            action=data.action_taken,
            reward=data.reward,
            performance={
                'cost': data.cost,
                'co2': data.co2,
                'autarky': data.autarky,
            }
        )
        
        return {
            "status": "success",
            "message": "Telemetrie aufgezeichnet",
            "timestamp": datetime.now().isoformat()
        }
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/telemetry/status")
@limiter.limit("60/minute")
async def telemetry_status(request: Request):
    """
    ℹ️ Telemetrie-Status abrufen
    
    Zeigt aktuellen Status der Telemetrie-Sammlung.
    """
    if not TELEMETRY_ENABLED:
        raise HTTPException(status_code=503, detail="Telemetry not available")
    
    try:
        collector = get_telemetry_collector()
        status = collector.get_status()
        
        return {
            "status": "success",
            "telemetry": status,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/telemetry/aggregate")
@limiter.limit("5/hour")
async def aggregate_telemetry(
    request: Request,
    _: None = Depends(verify_api_key)
):
    """
    📦 Aggregierte Telemetrie abrufen (Backend-to-Backend)
    
    Erstellt anonymisiertes Daten-Paket zur Übermittlung an
    zentrales Retraining-System.
    
    **Nur für autorisierte Backend-Services!**
    """
    if not TELEMETRY_ENABLED:
        raise HTTPException(status_code=503, detail="Telemetry not available")
    
    try:
        collector = get_telemetry_collector()
        aggregated = collector.get_aggregated_data()
        
        if aggregated is None:
            return {
                "status": "no_data",
                "message": "Nicht genug Daten oder Cooldown aktiv (Privacy Protection)",
                "timestamp": datetime.now().isoformat()
            }
        
        # An Federated Retrainer übergeben
        retrainer = get_federated_retrainer()
        retrainer.add_telemetry_batch(aggregated)
        
        return {
            "status": "success",
            "message": "Telemetrie aggregiert und an Retraining-System übermittelt",
            "data": aggregated,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.post("/telemetry/retrain")
@limiter.limit("1/day")
async def federated_retrain(
    request: Request,
    _: None = Depends(verify_api_key)
):
    """
    🔄 Federated Retraining starten (Admin-Only)
    
    Startet periodisches Retraining mit aggregierten Telemetrie-Daten.
    
    **Workflow:**
    1. Sammle Telemetrie von vielen Nutzern (anonymisiert)
    2. Aggregiere Daten zentral
    3. Trainiere DQN Agent
    4. Teste neues Modell
    5. OTA-Update an alle Fahrzeuge
    
    ⚠️ Nur 1x pro Tag erlaubt
    """
    if not TELEMETRY_ENABLED:
        raise HTTPException(status_code=503, detail="Telemetry not available")
    
    try:
        retrainer = get_federated_retrainer()
        
        if not retrainer.should_retrain():
            return {
                "status": "skipped",
                "message": "Retraining nicht nötig - zu wenig Daten oder zu früh",
                "stats": retrainer.get_stats(),
                "timestamp": datetime.now().isoformat()
            }
        
        results = await retrainer.retrain_agent()
        
        return {
            "status": "success",
            "message": "Federated Retraining abgeschlossen",
            "results": results,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))

@app.get("/telemetry/stats")
@limiter.limit("60/minute")
async def telemetry_stats(request: Request):
    """
    📈 Retraining-Statistiken abrufen
    
    Zeigt Status des Federated Learning Systems.
    """
    if not TELEMETRY_ENABLED:
        raise HTTPException(status_code=503, detail="Telemetry not available")
    
    try:
        retrainer = get_federated_retrainer()
        stats = retrainer.get_stats()
        
        collector = get_telemetry_collector()
        collector_status = collector.get_status()
        
        return {
            "status": "success",
            "retraining": stats,
            "collection": collector_status,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


# ==================== ISO 26262 SAFETY ENDPOINTS ====================

@app.get("/safety/status")
@limiter.limit("60/minute")
async def safety_status(request: Request):
    """
    🛡️ ISO 26262 Safety Status
    
    Gibt aktuellen Safety-Zustand des Systems zurück.
    
    **Includes:**
    - Safety State (NORMAL, WARNING, DEGRADED, SAFE_STATE, EMERGENCY_STOP)
    - Watchdog Status
    - Component Health
    - Recent Safety Events
    """
    if not SAFETY_ENABLED:
        return {
            "status": "disabled",
            "message": "ISO 26262 Safety Layer not enabled",
            "timestamp": datetime.now().isoformat()
        }
    
    try:
        safety = get_safety_monitor()
        status = safety.get_status()
        
        return {
            "status": "success",
            "safety": status,
            "timestamp": datetime.now().isoformat()
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/safety/events")
@limiter.limit("60/minute")
async def safety_events(
    request: Request,
    limit: int = 100,
    asil_filter: Optional[str] = None
):
    """
    📋 Safety Events Log
    
    Ruft letzte Safety Events ab (ISO 26262 Compliance).
    
    **Query Parameters:**
    - `limit`: Anzahl Events (default: 100)
    - `asil_filter`: Filter nach ASIL Level (QM, ASIL_A, ASIL_B, ASIL_C, ASIL_D)
    """
    if not SAFETY_ENABLED:
        raise HTTPException(status_code=503, detail="Safety Layer not available")
    
    try:
        safety = get_safety_monitor()
        
        # Convert ASIL filter string to enum
        asil_enum = None
        if asil_filter:
            try:
                asil_enum = ASILLevel[asil_filter]
            except KeyError:
                raise HTTPException(
                    status_code=400,
                    detail=f"Invalid ASIL level: {asil_filter}. Valid: QM, ASIL_A, ASIL_B, ASIL_C, ASIL_D"
                )
        
        events = safety.get_safety_events(limit=limit, asil_filter=asil_enum)
        
        return {
            "status": "success",
            "events": events,
            "total_events": len(events),
            "asil_filter": asil_filter,
            "timestamp": datetime.now().isoformat()
        }
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/safety/diagnostics")
@limiter.limit("30/minute")
async def safety_diagnostics(request: Request):
    """
    🔍 Safety System Diagnostics
    
    Umfassende Diagnostik-Informationen für OEM-Integration.
    
    **Includes:**
    - System Status
    - Recent Violations
